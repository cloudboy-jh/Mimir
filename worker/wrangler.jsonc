{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "mimir",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-13",
  "observability": { "enabled": true },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "mimir",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID",
      "migrations_dir": "migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "LOGS",
      "bucket_name": "mimir-logs"
    }
  ]
}
