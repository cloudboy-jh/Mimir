{
  "name": "mimir-worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build:dashboard": "bun --cwd=web run build",
    "deploy": "bun run build:dashboard && wrangler deploy",
    "test": "vitest run",
    "test:migrations": "node scripts/verify-migrations.mjs",
    "typecheck": "tsc --noEmit && tsc --noEmit -p test/tsconfig.json && bun --cwd=web run typecheck"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "jose": "^6.1.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.26.1"
  }
}
